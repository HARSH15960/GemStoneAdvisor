<%- include('partials/header') %>
<%- include('partials/navbar') %>

<div class="main-container" style="display: flex; align-items: center; justify-content: center; min-height: 70vh;">
  <div class="glass-panel" style="max-width: 550px; width: 100%; padding: 3rem; text-align: center; border-color: rgba(239, 68, 68, 0.3);">
    <i class="fa-solid fa-triangle-exclamation" style="font-size: 4rem; color: #f87171; margin-bottom: 1.5rem;"></i>
    <h2 style="font-size: 2rem; color: var(--text-white); margin-bottom: 1rem;">
      <%= error && error.status ? error.status : 'Oops!' %>
    </h2>
    <p style="color: var(--text-muted); font-size: 1.1rem; margin-bottom: 2rem;">
      <%= message || 'An unexpected error has occurred on the server.' %>
    </p>
    
    <% if (error && error.stack && process.env.NODE_ENV !== 'production') { %>
      <pre style="text-align: left; background: rgba(0,0,0,0.4); padding: 1rem; border-radius: 8px; overflow-x: auto; font-size: 0.8rem; color: #f87171; margin-bottom: 2rem; border: 1px solid rgba(255,255,255,0.05);"><%= error.stack %></pre>
    <% } %>

    <div style="display: flex; gap: 1rem; justify-content: center;">
      <a href="/" class="btn btn-primary"><i class="fa-solid fa-home"></i> Go Home</a>
      <button onclick="window.history.back()" class="btn btn-secondary"><i class="fa-solid fa-arrow-left"></i> Go Back</button>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
