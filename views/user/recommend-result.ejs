<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="main-container result-container">
  <!-- Back navigation -->
  <div style="margin-bottom: 1.5rem; display: flex; justify-content: space-between; align-items: center;">
    <a href="/user/dashboard" style="color: var(--text-muted);"><i class="fa-solid fa-arrow-left"></i> Dashboard Overview</a>
    <button onclick="window.print()" class="btn btn-secondary btn-small"><i class="fa-solid fa-print"></i> Print Astro-Report</button>
  </div>

  <div class="glass-panel result-card">
    <!-- Cosmic Header Banner -->
    <div class="result-banner">
      <div style="font-size: 2.5rem; color: var(--color-gold); margin-bottom: 0.5rem;"><i class="fa-solid fa-star-of-david floating-gem"></i></div>
      <h2>Cosmic Alignment Report</h2>
      <p>Astrological Gemstone Diagnostics</p>
    </div>

    <div class="result-body">
      <!-- Subject Birth details -->
      <h3 style="font-size: 1.2rem; color: var(--text-white); margin-bottom: 1rem; text-transform: uppercase; letter-spacing: 0.05em; border-bottom: 1px solid var(--border-glass); padding-bottom: 0.5rem;">
        Subject Profile
      </h3>
      <div class="profile-card">
        <div class="profile-info-item">
          <span>Name</span>
          <strong><%= recommendation.fullName %></strong>
        </div>
        <div class="profile-info-item">
          <span>Gender</span>
          <strong><%= recommendation.gender %></strong>
        </div>
        <div class="profile-info-item">
          <span>Date of Birth</span>
          <strong><%= new Date(recommendation.dob).toLocaleDateString() %></strong>
        </div>
        <div class="profile-info-item">
          <span>Zodiac Sign</span>
          <strong><%= recommendation.zodiacSign %></strong>
        </div>
        <div class="profile-info-item">
          <span>Focus Aspect</span>
          <strong><%= recommendation.problemCategory %></strong>
        </div>
      </div>

      <!-- Compatibility Scorecard -->
      <div class="score-card-wrapper" style="--percentage-fill: <%= recommendation.compatibilityScore %>%">
        <div class="score-radial">
          <div class="score-value"><%= recommendation.compatibilityScore %>%</div>
        </div>
        <div class="score-details-pane">
          <h4 style="font-family: var(--font-display); font-weight: 600; color: var(--text-white);">Astrological Affinity Score</h4>
          <p>
            This gemstone alignment shows an outstanding structural resonance with your natal chart planetary houses under current periods.
          </p>
          <div style="margin-top: 0.8rem; display: flex; gap: 0.5rem; flex-wrap: wrap;">
            <span class="badge badge-gold"><i class="fa-solid fa-bolt"></i> Planet Strength: <%= recommendation.planetStrength || 'Strong' %></span>
            <span class="badge badge-primary"><i class="fa-solid fa-bullseye"></i> Recommended For: 
              <% if (recommendation.problemCategory === 'Career') { %>
                Career Growth, Leadership, Confidence
              <% } else if (recommendation.problemCategory === 'Business') { %>
                Trade Success, Negotiation, Strategy
              <% } else if (recommendation.problemCategory === 'Money') { %>
                Wealth Attraction, Savings, Stability
              <% } else if (recommendation.problemCategory === 'Marriage') { %>
                Marital Bliss, Family Harmony, Connection
              <% } else if (recommendation.problemCategory === 'Education') { %>
                Concentration, Memory, Academic Success
              <% } else { %>
                Vitality, Mental Peace, Energy Protection
              <% } %>
            </span>
          </div>
        </div>
      </div>

      <!-- Why This Recommendation Card -->
      <div class="glass-panel" style="padding: 2rem; margin-bottom: 2.5rem; border-color: rgba(251, 191, 36, 0.2); background: linear-gradient(135deg, rgba(25, 28, 59, 0.3) 0%, rgba(251, 191, 36, 0.02) 100%);">
        <h4 style="font-size: 1.15rem; color: var(--text-white); margin-bottom: 0.75rem; font-family: var(--font-display); display: flex; align-items: center; gap: 0.5rem;">
          <i class="fa-solid fa-circle-question text-gold"></i> Why This Recommendation?
        </h4>
        <p style="color: var(--text-muted); font-size: 0.95rem; line-height: 1.6; font-family: var(--font-sans);">
          <%= recommendation.whyExplanation %>
        </p>
      </div>

      <!-- Gemstone recommendation display -->
      <h3 class="gem-showcase-title">Recommended Cosmic Crystals</h3>

      <% if (recommendation.recommendedGemstones && recommendation.recommendedGemstones.length > 0) { %>
        <% recommendation.recommendedGemstones.forEach(gem => { %>
          <% if (gem) { %>
            <div class="gem-detail-section">
              <div>
                <img src="<%= gem.image %>" alt="<%= gem.name %>" class="gem-detail-img">
              </div>
              
              <div>
                <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 0.75rem;">
                  <h3 style="font-size: 1.8rem; color: var(--text-white);"><%= gem.name %></h3>
                  
                  <!-- Favorite toggle form -->
                  <form action="/user/favorites/toggle" method="POST" class="favorite-toggle-form">
                    <input type="hidden" name="gemstoneId" value="<%= gem._id %>">
                    <% if (favoriteGemIds.includes(gem._id.toString())) { %>
                      <button type="submit" class="btn btn-gold btn-small btn-fav-toggle">★ Favorited</button>
                    <% } else { %>
                      <button type="submit" class="btn btn-secondary btn-small btn-fav-toggle">☆ Add to Favorites</button>
                    <% } %>
                  </form>
                </div>

                <div class="gem-planet" style="font-size: 1rem; margin-bottom: 1rem;">
                  <i class="fa-solid fa-sun" style="color: var(--color-gold);"></i> Ruling Planet: <%= gem.planet %>
                </div>

                <p style="color: var(--text-muted); font-size: 0.95rem; line-height: 1.6; margin-bottom: 1.5rem;">
                  <%= gem.description %>
                </p>

                <h4 style="font-size: 0.9rem; color: var(--text-white); text-transform: uppercase; letter-spacing: 0.05em;">Wear Instructions & Metals</h4>
                <div class="gem-meta" style="margin-top: 0.5rem; margin-bottom: 1.5rem;">
                  <div class="meta-item">
                    <span>Wear Day</span>
                    <strong><%= gem.wearDay %></strong>
                  </div>
                  <div class="meta-item">
                    <span>Metal</span>
                    <strong><%= gem.metal %></strong>
                  </div>
                  <div class="meta-item">
                    <span>Price Range</span>
                    <strong><%= gem.priceRange %></strong>
                  </div>
                </div>

                <% if (gem.benefits && Array.isArray(gem.benefits) && gem.benefits.length > 0) { %>
                  <h4 style="font-size: 0.9rem; color: var(--text-white); text-transform: uppercase; letter-spacing: 0.05em;">Cosmic Benefits</h4>
                  <ul class="gem-benefits-list">
                    <% gem.benefits.forEach(benefit => { %>
                      <li><%= benefit %></li>
                    <% }) %>
                  </ul>
                <% } %>
              </div>
            </div>
          <% } %>
        <% }) %>
      <% } else { %>
        <p style="text-align: center; color: var(--text-muted);">No matching gemstones found. Please consult an administrator.</p>
      <% } %>
    </div>
  </div>

  <div style="display: flex; gap: 1rem; justify-content: center; margin-top: 2rem;">
    <a href="/user/recommend" class="btn btn-primary"><i class="fa-solid fa-rotate-left"></i> Run Another Alignment</a>
    <a href="/user/history" class="btn btn-secondary"><i class="fa-solid fa-history"></i> Recommendation History</a>
  </div>
</div>

<%- include('../partials/footer') %>
